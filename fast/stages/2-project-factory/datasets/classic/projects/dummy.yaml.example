# # yaml-language-server: $schema=../../schemas/project.schema.json

# # Exhaustive Reference Example for FAST Project Factory Stage
# # This file serves as a complete reference of all top-level configurations that can be defined
# # for a project created via the project factory YAML dataset.
# # It does not override the schema but demonstrates all supported configurations.

# # Unique billing account override for this specific project.
# # If not set, the dataset defaults or stage variable will be used.
# billing_account: 012345-67890A-BCDEF0

# # Google Cloud parent resource ID for the project (e.g. "folders/1234567890")
# parent: folders/1234567890

# # Prefix to use for this project instead of the global prefix
# prefix: prod

# # Descriptive project name (the resource name of the project in GCP console)
# descriptive_name: "Production Dummy Reference Project"

# # Identifies a template for project settings, if used
# project_template: null

# # Deletion policy: PREVENT (protect from deletion), DELETE (allow deletion), ABANDON
# deletion_policy: PREVENT

# # Project services (APIs) to enable in this project
# services:
#   - compute.googleapis.com
#   - container.googleapis.com
#   - bigquery.googleapis.com
#   - storage.googleapis.com
#   - pubsub.googleapis.com

# # Advanced: Existing project reuse configuration, useful if adopting an existing project
# project_reuse:
#   use_data_source: false
#   attributes:
#     name: existing-project-id
#     number: 123456789012
#     services_enabled:
#       - compute.googleapis.com

# # Cloud Storage buckets to create in the project
# buckets:
#   my-test-bucket:
#     location: europe-west1
#     storage_class: STANDARD
#     uniform_bucket_level_access: true
#     versioning: true
#     soft_delete_retention: 7
#     enable_object_retention: false
#     force_destroy: true
#     labels:
#       env: prod
#       team: devops
#     soft_delete_retention: 7
#     retention_policy:
#       retention_period: 2592000s # 30 days
#       is_locked: false
#     lifecycle_rules:
#       delete-after-90-days:
#         action:
#           type: Delete
#         condition:
#           age: 90
#           matches_storage_class:
#             - STANDARD
#     logging_config:
#       log_bucket: my-logging-bucket
#       log_object_prefix: my-test-bucket-logs/
#     managed_folders:
#       "confidential/":
#         force_destroy: true
#         iam:
#           roles/storage.objectViewer:
#             - group:dev-group@example.com
#     tag_bindings:
#       environment: prod

# # IAM policy for the project
# iam:
#   roles/owner:
#     - user:admin@example.com
#   roles/viewer:
#     - group:viewers@example.com

# # Authoritative IAM bindings for specific roles
# iam_bindings:
#   cloud-build-admins:
#     role: roles/cloudbuild.builds.editor
#     members:
#       - user:builder@example.com
#     condition:
#       title: "only during daytime"
#       description: "Access condition example"
#       expression: "request.time.getHours('America/New_York') > 9"

# # Additive IAM bindings (safe for merging)
# iam_bindings_additive:
#   add-sa-viewer:
#     member: user:dev@example.com
#     role: roles/viewer

# # Direct mapping of IAM roles by individual principals
# iam_by_principals:
#   user:engineer@example.com:
#     - roles/viewer
#     - roles/compute.networkUser

# # Conditional IAM roles by individual principals
# iam_by_principals_conditional:
#   user:support-lead@example.com:
#     roles:
#       - roles/viewer
#     condition:
#       title: "valid_until_end_of_2026"
#       expression: "request.time < timestamp('2027-01-01T00:00:00Z')"

# # Metric scopes (Monitoring scopes) to configure for this project
# metric_scopes:
#   - projects/another-monitoring-project-id

# # Cloud KMS keyrings and keys to create in the project
# kms:
#   keyrings:
#     my-keyring:
#       location: europe-west1
#       keys:
#         my-crypto-key:
#           rotation_period: 7776000s # 90 days
#           destroy_scheduled_duration: 86400s # 1 day
#           purpose: ENCRYPT_DECRYPT
#           version_template:
#             algorithm: GOOGLE_SYMMETRIC_ENCRYPTION
#             protection_level: SOFTWARE
#           iam:
#             roles/cloudkms.cryptoKeyEncrypterDecrypter:
#               - serviceAccount:compute-system@example.iam.gserviceaccount.com

# # Custom labels to add to the project
# labels:
#   environment: production
#   billing_code: "12345"
#   application_id: my-app

# # Shared VPC configuration for the project:
# # Configure this project as a Shared VPC Service Project
# shared_vpc_service_config:
#   host_project: my-shared-vpc-host-project-id
#   network_users:
#     - serviceAccount:my-project-sa@prod-dummy.iam.gserviceaccount.com
#   network_subnet_users:
#     europe-west1/default:
#       - user:dev@example.com

# # OR Configure this project as a Shared VPC Host Project
# shared_vpc_host_config:
#   enabled: false
#   service_projects:
#     - my-first-service-project

# # Service Accounts to create in this project
# service_accounts:
#   project-worker:
#     display_name: "Project Worker Service Account"
#     iam_self_roles:
#       - roles/logging.logWriter
#     iam_project_roles:
#       prod-dummy:
#         - roles/storage.objectAdmin
#     tag_bindings:
#       environment: prod

# # Cloud Asset feeds to enable in this project
# asset_feeds:
#   storage-changes:
#     content_type: RESOURCE
#     asset_types:
#       - storage.googleapis.com/Bucket
#     feed_output_config:
#       pubsub_destination:
#         topic: projects/prod-dummy/topics/my-pubsub-topic
#     condition:
#       expression: "true"
#       title: "All Changes"

# # Essential contacts for the project
# contacts:
#   admin@example.com:
#     - ALL
#   security-team@example.com:
#     - SECURITY

# # Data Access logs settings
# data_access_logs:
#   allServices:
#     ADMIN_READ:
#       exempted_members:
#         - user:admin@example.com
#     DATA_READ:
#       exempted_members:
#         - group:data-readers@example.com

# # BigQuery datasets to create in the project
# datasets:
#   my_dataset:
#     friendly_name: "My Main Dataset"
#     location: EU
#     options:
#       default_table_expiration_ms: 2592000000 # 30 days
#       delete_contents_on_destroy: false
#       max_time_travel_hours: 48
#     iam:
#       roles/bigquery.dataEditor:
#         - group:data-editors@example.com

# # Cloud logging buckets to create in the project
# log_buckets:
#   my-custom-log-bucket:
#     location: europe-west1
#     retention: 30
#     description: "Production logging bucket"
#     log_analytics:
#       enable: true

# # Project factory configurations override (custom roles, policies, tags folders)
# factories_config:
#   custom_roles: "datasets/classic/custom-roles"
#   org_policies: "datasets/classic/org-policies"
#   quotas: "datasets/classic/quotas"
#   tags: "datasets/classic/tags"

# # PAM (Privileged Access Management) Entitlements
# pam_entitlements:
#   admin-access-entitlement:
#     max_request_duration: 7200s
#     eligible_users:
#       - user:engineer@example.com
#     privileged_access:
#       - role: roles/owner
#         condition: "request.time < timestamp('2026-12-31T23:59:59Z')"
#     requester_justification_config:
#       unstructured: true
#     manual_approvals:
#       require_approver_justification: true
#       steps:
#         - approvers:
#             - user:manager@example.com
#           approvals_needed: 1

# # Organisation-level policy overrides applied only at this project level
# org_policies:
#   compute.disableSerialPortAccess:
#     inherit_from_parent: false
#     rules:
#       - enforce: true
#   compute.trustedImageProjects:
#     rules:
#       - allow:
#           values:
#             - projects/my-trusted-image-project

# # Pub/Sub Topics to create in the project
# pubsub_topics:
#   my-pubsub-topic:
#     kms_key: projects/prod-dummy/locations/europe-west1/keyRings/my-keyring/cryptoKeys/my-crypto-key
#     labels:
#       env: prod
#     message_retention_duration: 604800s # 7 days
#     iam:
#       roles/pubsub.publisher:
#         - serviceAccount:my-source-sa@example.iam.gserviceaccount.com
#     subscriptions:
#       my-sub:
#         ack_deadline_seconds: 10
#         enable_exactly_once_delivery: true
#         expiration_policy_ttl: 2592000s # 30 days
#         retry_policy:
#           minimum_backoff: 10
#           maximum_backoff: 600
#         push:
#           endpoint: https://example.com/push-endpoint

# # Service specific encryption key mappings
# service_encryption_key_ids:
#   compute.googleapis.com:
#     - projects/prod-dummy/locations/europe-west1/keyRings/my-keyring/cryptoKeys/my-crypto-key

# # Resource Tag Bindings for the project
# tag_bindings:
#   environment: production
#   team: devops

# # Quota override settings
# quotas:
#   compute-cpus:
#     service: compute.googleapis.com
#     quota_id: "CPUS"
#     preferred_value: 20
#     justification: "Need more CPU quota for web servers"
